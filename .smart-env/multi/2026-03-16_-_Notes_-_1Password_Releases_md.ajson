01984084,0.00403913,0.20254976,-0.00063296,-0.03952747,0.00078014,0.04704564,0.00913581,0.07196808,0.02608877,-0.01507944,-0.00500797,0.07246023,0.00834383,0.00888795,-0.00909782,0.00211294,-0.02066621,0.047589,0.03815273,-0.04886418,0.03822816,-0.02808098,-0.02020869,0.06827651,-0.01816765,0.0376844,0.01746715,0.03045811,0.01506279,-0.05285102,-0.05839632,-0.00617708,0.00263184,-0.00088233,0.04804466,0.01064262,-0.05015458,-0.01447658,0.0376851,0.06277138,-0.04630376,0.05074016,-0.02512968,0.07329116],"last_embed":{"hash":"1d0bbrp","tokens":449}}},"last_read":{"hash":"1d0bbrp","at":1774917059268},"class_name":"SmartSource","last_import":{"mtime":1774917041354,"size":162193,"at":1774917058501,"hash":"1d0bbrp"},"blocks":{"#---frontmatter---":[1,7],"#":[8,19],"###What's new":[20,1490],"###What's new#{1}":[22,1489],"###What's new#{2}":[1490,1490]},"outlinks":[{"title":"Dave","target":"Dave","line":4},{"title":"1Password 8 for Windows","target":"https://releases.1password.com/windows/stable/HeroUnlocked.png","line":8,"embedded":true},{"title":"Download 1Password for Windows","target":"https://downloads.1password.com/win/1PasswordSetup-latest.msixbundle","line":12},{"title":"1Password Support Community","target":"https://www.1password.community/?utm_source=releasenotes","line":14},{"title":"RSS feed","target":"https://releases.1password.com/windows/stable/index.xml","line":16},{"title":"contact 1Password Support","target":"https://1password.com/contact-support","line":31},{"title":"#AUTH-2005!35083\r\n- If you load an empty `.env` file in **Developer** > **Environments**, it will now show a message saying no variables were found. #DG-7!35144\r\n- We’ve fixed an issue that could cause 1Password to crash when you signed in to a device. #PA-346!35258\r\n- We’ve fixed an issue that could block in-app updates if the MDM setting for automatic updates was enabled for MSI installs. #PA-941!35295\r\n\r\n- 1Password now supports a wider set of custom trusted browsers on Windows. #PA-901!34408\r\n- We’ve added a new developer setting to enable SDK integrations, so you can authenticate SDKs with authorization prompts from the 1Password desktop app. #39275\r\n- We’ve fixed an issue where a prompt to turn on two-factor authentication couldn’t be selected. #AUTH-160!34473\r\n- We’ve fixed an issue where the Windows Hello prompt could appear behind other windows or seem unresponsive. #DV-446!34963\r\n\r\n- We’ve fixed an issue where Windows Hello prompts could appear behind app and browser windows. #RO-800\r\n\r\n- We’ve Fixed an issue with an unclickable prompt when being asked to enable two-factor authentication during sign-in.!34473\r\n- You now only see the Windows Passkeys setup prompt if an unlocked account has the setting “Passkey item support” enabled. #FS-4434!34387\r\n- We’ve improved localization for a number of our supported languages. If you’d like to suggest a localization improvement, [contact 1Password Support","target":"https://1password.com/contact-support","line":33},{"title":"connect additional browsers","target":"https://support.1password.com/additional-browsers/?windows","line":60},{"title":"installed the MSIX version of 1Password","target":"https://support.1password.com/cs/1password-msix-installer/#what-to-know","line":71},{"title":"MSIX beta","target":"https://www.1password.community/discussions/1password/beta-release-new-msix-installer-for-1password-for-windows/155230","line":147},{"title":"too many authentication failures","target":"https://developer.1password.com/docs/ssh/agent/advanced#ssh-server-six-key-limit","line":178},{"title":"Labs","target":"https://support.1password.com/labs/","line":194},{"title":"See the accompanying article for more information.","target":"https://support.1password.com/kb/202408c/","line":357},{"title":"GetApp","target":"https://www.getapp.com/security-software/a/1password/","line":379},{"title":"GetApp","target":"https://www.getapp.com/security-software/a/1password/","line":416},{"title":"recovery codes","target":"https://support.1password.com/recovery-codes/","line":420},{"title":"GetApp","target":"https://www.getapp.com/security-software/a/1password/","line":436},{"title":"Unicode Consortium","target":"https://cldr.unicode.org/","line":491},{"title":"insights about developer credentials","target":"https://developer.1password.com/docs/watchtower/","line":518},{"title":"“Configure for WSL”","target":"https://developer.1password.com/docs/ssh/integrations/wsl/","line":536},{"title":"sign Git commits","target":"https://developer.1password.com/docs/ssh/git-commit-signing/","line":571},{"title":"security advisory","target":"https://support.1password.com/kb/202309/","line":632},{"title":"diagnostics reports","target":"https://support.1password.com/diagnostics/","line":649},{"title":"Contact 1Password Support","target":"https://support.1password.com/contact/","line":651},{"title":"contact 1Password Support","target":"https://support.1password.com/contact/","line":653},{"title":"use 1Password to sign in to sites","target":"https://support.1password.com/sign-in-with-provider/","line":675},{"title":"1Password Shell Plugins","target":"https://developer.1password.com/docs/cli/shell-plugins","line":717},{"title":"create the config file for the 1Password SSH agent","target":"https://developer.1password.com/docs/ssh/agent/config/","line":723},{"title":"secret references","target":"https://developer.1password.com/docs/cli/secret-references/","line":755},{"title":"supported sign-in provider","target":"https://support.1password.com/sign-in-with-provider/","line":854},{"title":"SSH agent","target":"https://developer.1password.com/docs/ssh/agent","line":884},{"title":"contact our business support team","target":"https://1password.com/contact-us/","line":1004},{"title":"1Password 8","target":"https://1password.com/products/","line":1015},{"title":"1Password extension","target":"https://1password.com/downloads/windows/#browsers","line":1118},{"title":"Trusted Platform Module (TPM) with Windows Hello to unlock 1Password","target":"https://support.1password.com/windows-hello/#manage-your-settings","line":1205},{"title":"Your CLI wish is our command","target":"https://blog.1password.com/1password-cli-2.0/","line":1218},{"title":"SSH and Git, meet 1Password","target":"https://blog.1password.com/1password-ssh-agent/","line":1218},{"title":"Screenshot of the untagged advanced search scope in action","target":"https://releases.1password.com/img/rn/b8.5.0.10-untagged-advanced-search-scope.png","line":1307,"embedded":true},{"title":"Screenshot of the new Developer section under Settings","target":"https://releases.1password.com/img/rn/b8.5.0.10-developer-preferences-window-coming-soon.png","line":1311,"embedded":true},{"title":"1Password Quick Access window with a custom collection selected using the new keyboard shortcuts","target":"https://releases.1password.com/img/rn/b8.4.0.46-quick-access-hero-custom-collection.png","line":1317,"embedded":true},{"title":"1Password 8","target":"https://1password.com/products/","line":1319},{"title":"hear from you","target":"https://1password.community/categories/desktop-betas","line":1319},{"title":"saving QRCodes in your browser","target":"https://support.1password.com/one-time-passwords/#set-up-two-factor-authentication-for-a-website","line":1321},{"title":"An item being edited with a QRCode scanner icon shown on a one-time password field","target":"https://releases.1password.com/img/rn/b8.5.0.79-scan-2fa-qrcodes-in-app.png","line":1323,"embedded":true},{"title":"An item list scrolled to the very end, revealing the number of items in the list","target":"https://releases.1password.com/img/rn/b8.5.0.79-item-counts.png","line":1327,"embedded":true},{"title":"Quick Access with the account and collection selection open","target":"https://releases.1password.com/img/rn/b8.5.0.79-quick-access-collection-selection.png","line":1331,"embedded":true},{"title":"Psst!","target":"https://blog.1password.com/psst-item-sharing/","line":1333},{"title":"The sharing window for an item showing who it is being shared with along with the new View history button","target":"https://releases.1password.com/img/rn/b8.5.0.83-item-sharing-details-view-history.png","line":1335,"embedded":true},{"title":"The sharing history for my pie recipe after I shared it with my newsletter subscribers","target":"https://releases.1password.com/img/rn/b8.5.0.83-item-sharing-history.png","line":1339,"embedded":true},{"title":"A Watchtower banner pointing out that an item has a weak or vulnerable password, along with a Change Password button","target":"https://releases.1password.com/img/rn/b8.5.0.102-change-password.png","line":1343,"embedded":true},{"title":"Preferences window with new Appearance tab selected","target":"https://releases.1password.com/img/rn/b8.5.0.102-apperance-preferences.png","line":1347,"embedded":true},{"title":"A screenshot of the sidebar with a tag selected along with a context menu with the Delete menu item highlighted","target":"https://releases.1password.com/img/rn/b8.5.0.102-delete-tag-from-sidebar.png","line":1351,"embedded":true},{"title":"Psst!","target":"https://blog.1password.com/psst-item-sharing/","line":1371},{"title":"Masked Email","target":"https://1password.com/fastmail/","line":1392},{"title":"Emergency Kit","target":"https://support.1password.com/emergency-kit/","line":1425}],"metadata":{"source":"https://releases.1password.com/windows/stable/#changelog","author":["[[Dave]]"],"published":"2026-03-16","created":"2026-03-30","tags":["#PA-852","#KNOX-615","#DV-446","#AUTH-2056","#AUTH-2005","#DG-7","#PA-346","#PA-941","#PA-901","#AUTH-160","#RO-800","#FS-4434","#PA-874","#PA-878","#PA-883","#SET-12","#SET-344","#DA-1725","#DA-1723","#PA-895","#PA-872","#DG-70","#DG-43","#DA-106","#DA-19","#PA-859","#PA-844","#PA-848","#DG-18","#FRAM-11"]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1d0bbrp","at":1774917058799}},"smart_blocks:2026-03-16 - Notes - 1Pa