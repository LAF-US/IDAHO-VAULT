{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://idaho-vault.local/schemas/manifest.schema.json",
  "title": "IDAHO-VAULT Manifest",
  "type": "object",
  "required": [
    "manifest_version",
    "generated_at",
    "authority",
    "sync",
    "mcp",
    "locks",
    "entries"
  ],
  "properties": {
    "manifest_version": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "authority": {
      "type": "object",
      "required": ["canonical_system", "interface_system", "fallback_mode"],
      "properties": {
        "canonical_system": { "const": "github" },
        "interface_system": { "const": "obsidian" },
        "fallback_mode": { "const": "filesystem" }
      },
      "additionalProperties": false
    },
    "sync": {
      "type": "object",
      "required": ["primary_dataset", "sync_unit", "trigger_model"],
      "properties": {
        "primary_dataset": { "const": "vault" },
        "sync_unit": {
          "type": "array",
          "items": { "type": "string", "enum": ["file", "manifest_entry"] },
          "minItems": 2
        },
        "trigger_model": { "const": "event_based_write_read_cycle" }
      },
      "additionalProperties": false
    },
    "mcp": {
      "type": "object",
      "required": ["enabled", "mode", "server", "notes"],
      "properties": {
        "enabled": { "type": "boolean" },
        "mode": { "const": "transport_only" },
        "server": { "type": ["string", "null"] },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "locks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["lock_id", "file_path", "agent_id", "created_at", "expires_at", "state"],
        "properties": {
          "lock_id": { "type": "string" },
          "file_path": { "type": "string" },
          "agent_id": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "expires_at": { "type": "string", "format": "date-time" },
          "state": { "type": "string", "enum": ["active", "released", "expired"] }
        },
        "additionalProperties": false
      }
    },
    "entries": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "content_hash",
          "last_writer",
          "last_write_at",
          "last_read_at",
          "status",
          "lock_id",
          "version"
        ],
        "properties": {
          "content_hash": { "type": "string" },
          "last_writer": { "type": "string" },
          "last_write_at": { "type": "string", "format": "date-time" },
          "last_read_at": { "type": "string", "format": "date-time" },
          "status": { "type": "string" },
          "lock_id": { "type": ["string", "null"] },
          "version": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
