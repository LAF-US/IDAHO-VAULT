{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://idaho-vault.local/schemas/manifest.schema.json",
  "title": "IDAHO-VAULT Manifest",
  "type": "object",
  "required": [
    "manifest_version",
    "generated_at",
    "authority",
    "sync",
    "mcp",
    "obsidian_templates",
    "locks",
    "entries"
  ],
  "properties": {
    "manifest_version": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "authority": {
      "type": "object",
      "required": ["canonical_system", "execution_system", "interface_system", "fallback_mode"],
      "properties": {
        "canonical_system": { "const": "vault" },
        "execution_system": { "const": "github" },
        "interface_system": { "const": "obsidian" },
        "fallback_mode": { "const": "filesystem" }
      },
      "additionalProperties": false
    },
    "sync": {
      "type": "object",
      "required": ["primary_dataset", "sync_unit", "trigger_model"],
      "properties": {
        "primary_dataset": { "const": "vault" },
        "sync_unit": {
          "type": "array",
          "items": { "type": "string", "enum": ["file", "manifest_entry"] },
          "minItems": 2
        },
        "trigger_model": { "const": "event_based_write_read_cycle" }
      },
      "additionalProperties": false
    },
    "mcp": {
      "type": "object",
      "required": ["enabled", "mode", "server", "notes"],
      "properties": {
        "enabled": { "type": "boolean" },
        "mode": { "const": "transpo***REMOVED***only" },
        "server": { "type": ["string", "null"] },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "obsidian_templates": {
      "type": "object",
      "required": ["source_of_truth", "concrete_bindings", "folder_bindings", "untracked_plugins"],
      "properties": {
        "source_of_truth": { "const": "tracked_obsidian_config" },
        "concrete_bindings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["client", "plugin", "config_path", "template_path", "mode", "status", "note_folder"],
            "properties": {
              "client": { "const": "obsidian" },
              "plugin": { "type": "string" },
              "config_path": { "type": "string" },
              "template_path": { "type": "string" },
              "mode": { "type": "string" },
              "status": { "type": "string" },
              "note_folder": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "folder_bindings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["client", "plugin", "config_path", "folder", "date_format", "time_format", "status", "note"],
            "properties": {
              "client": { "const": "obsidian" },
              "plugin": { "type": "string" },
              "config_path": { "type": "string" },
              "folder": { "type": "string" },
              "date_format": { "type": "string" },
              "time_format": { "type": "string" },
              "status": { "type": "string" },
              "note": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "untracked_plugins": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["client", "plugin", "status", "config_path", "note"],
            "properties": {
              "client": { "const": "obsidian" },
              "plugin": { "type": "string" },
              "status": { "type": "string" },
              "config_path": { "type": "string" },
              "note": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "locks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["lock_id", "file_path", "agent_id", "created_at", "expires_at", "state"],
        "properties": {
          "lock_id": { "type": "string" },
          "file_path": { "type": "string" },
          "agent_id": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "expires_at": { "type": "string", "format": "date-time" },
          "state": { "type": "string", "enum": ["active", "released", "expired"] }
        },
        "additionalProperties": false
      }
    },
    "entries": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "content_hash",
          "last_writer",
          "last_write_at",
          "last_read_at",
          "status",
          "lock_id",
          "version"
        ],
        "properties": {
          "content_hash": { "type": "string" },
          "last_writer": { "type": "string" },
          "last_write_at": { "type": "string", "format": "date-time" },
          "last_read_at": { "type": "string", "format": "date-time" },
          "status": { "type": "string" },
          "lock_id": { "type": ["string", "null"] },
          "version": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
