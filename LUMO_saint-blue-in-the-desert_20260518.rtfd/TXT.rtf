\f0\b0 \cb1 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa30\partightenfactor0
\ls23\ilvl0\cf7 \cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec7 You don't know exactly how Chicago will feel when you get there.\cb1 \
