# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.Python
.python_history
!.python/
!.python/**

.venv/
venv/
env/
ENV/
.uv-cache/
.pip-cache/
*.egg-info/
build/
dist/

node_modules/
**/node_modules/
.npm-cache/

# External SDK/runtime installs parked locally are not vault content.
google-cloud-sdk/
LFPython/
feed-generator/
.local/share/claude/versions/
.ollama/models/blobs/
.ollama/models/manifests/

# ---------------------------------------------------------------------------
# Local caches, temp, state, and generated databases
