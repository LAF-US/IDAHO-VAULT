*.lock
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.db

logs/
**/logs/
**/cache/
**/.cache/
**/tool-results/
**/shared_proto_db/

# Local media-app cache artifacts, not source documents.
*.cfa
*.pek

