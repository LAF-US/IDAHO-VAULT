# Project-specific
.env
*.vault.json
.codex/tmp/
tmp-minidata-msg/
tmp-msg-extract/
_phone-link-sweep.log

# Local media app cache artifacts
*.cfa
*.pek

# AppleDouble sidecar files
._*

# Local machine secrets
.obsidian/plugins/obsidian-local-rest-api/data.json
# Swarm state archive (local only)
.github/swarm/state/archive/

# Swarm operational logs (ephemeral)
\!/swarm/logs/*
!\!/swarm/logs/.gitkeep

# Obsidian system/state files (noisy, machine-local)
.obsidian/workspace.json
.obsidian/workspace*.json
.obsidian/graph.json
.obsidian/types.json
.obsidian/backlink.json
.obsidian/file-recovery.json
.obsidian/page-preview.json
.obsidian/switcher.json
.obsidian/webviewer.json
.obsidian/note-composer.json

# Obsidian plugin runtime data / secrets (API keys live here — never commit)
.obsidian/plugins/*/data.json

# Obsidian plugin cache directories (machine-generated, not source-trackable)
.obsidian/plugins/*/cache/

# Obsidian plugin compiled binaries (too large, not source-trackable)
.obsidian/plugins/mcp-tools/bin/

# Smart Connections embedding cache (machine-generated, can be hundreds of MB)
.smart-env/
.obsidian/plugins/smart-connections/.smart-env/

# Obsidian conflict duplicates
.obsidian/**(2)*.json

# Daily notes (ephemeral, personal)
DAILYNOTES/

# Local runtime inbox artifacts (do not track phone-link intake payloads)
INBOX/PHONE-LINK/*

# Local conflicted duplicates and temp placeholders
* (Conflicted copy *).md
tempfolder.txt

# Claude Code local settings (machine-local, not for repo)
.claude/settings.local.json
.claude/worktrees/

# Ignore local MCP server binary
.obsidian/plugins/mcp-tools/bin/mcp-server.exe

# Obsidian plugin compiled assets (machine-generated, not source)
.obsidian/plugins/*/main.js
.obsidian/plugins/*/styles.css
.obsidian/plugins/*/manifest.json

# ---------------------------------------------------------------------------
# Binary & Media Assets
# ---------------------------------------------------------------------------
# These file types do not belong in git history — they inflate pack size
# dramatically and have no diff/merge value.
#
# For files that MUST be version-controlled (e.g. source graphics, GIS data),
# use Git LFS (.gitattributes) instead of committing them directly.
# See: https://git-lfs.github.com

