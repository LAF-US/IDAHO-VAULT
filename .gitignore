# Obsidian plugin cache directories (machine-generated, not source-trackable)
.obsidian/plugins/*/cache/
.makemd/
.space/
BMO/
Tags/

# Obsidian plugin compiled binaries (too large, not source-trackable)
.obsidian/plugins/mcp-tools/bin/
