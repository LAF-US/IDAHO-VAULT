.obsidian/plugins/*/styles.css
.obsidian/plugins/*/manifest.json

# Smart Connections embedding cache (machine-generated, can be hundreds of MB)
.smart-env/
.obsidian/plugins/smart-connections/.smart-env/

# Obsidian conflict duplicates
.obsidian/**(2)*.json

# Daily notes (ephemeral, personal)
DAILYNOTES/

# Local runtime inbox artifacts (do not track phone-link intake payloads)
INBOX/PHONE-LINK/*

