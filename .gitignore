# ---------------------------------------------------------------------------
# Obsidian local state and plugin runtime data
# ---------------------------------------------------------------------------
# Track vault-facing interface state and plugin manifests. Do not track private
# plugin data, caches, indexes, or machine-local workspace state.
.obsidian/workspace.json
.obsidian/workspace*.json
.obsidian/graph.json
.obsidian/types.json
.obsidian/backlink.json
.obsidian/file-recovery.json
.obsidian/page-preview.json
.obsidian/switcher.json
.obsidian/webviewer.json
.obsidian/note-composer.json
.obsidian/app.json
.obsidian/appearance.json

.obsidian/plugins/*/data.json
