# IDAHO-VAULT gitignore
#
# First principle: the vault is the record. Markdown notes, structured
# registries, scripts, source documents, media, attachments, and durable agent
# memory stay visible to git by default.
#
# This file exists mainly to shield secrets and suppress machine churn. It
# excludes local runtime state, dependency installs, caches, logs, credentials,
# editor/workspace noise, and NETWEB-invalid names. Existing tracked files are
# not untracked by these rules; use explicit git index cleanup when Logan
# decides a tracked artifact is no longer part of the record.

# ---------------------------------------------------------------------------
# Secrets and credentials
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template
.envrc

.op/openrouter.env
.op/reports/
.mcp-auth/
secrets/
vault-courier-key.json
*-key.json
*service-account.json
archive-secrets-*.json
application_default_credentials.json
credentials.json
token.json
tokens.json
oauth*.json
client_secret*.json

# Private key material and local certificate/key stores.
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
known_hosts

# Tool/package manager auth files commonly containing tokens.
.npmrc
.pypirc
.netrc
.aws/
.azure/
.config/gcloud/
.gsutil/
.config/rclone/
rclone.conf
*.rclone.conf

# Credential exports and recovery codes must never enter the public record.
Google Passwords.csv
**/Google Passwords*.csv
**/passwords*.csv
*recovery-codes*
*recovery_codes*

# Tool auth state
.claude/.credentials.json
.codex/auth.json
.codex/.codex-global-state.json
.pi/agent/auth.json
.gemini/oauth_creds.json
.gemini/google_accounts.json
.factory/auth.v2.*
.openclaw/credentials/

# ---------------------------------------------------------------------------
