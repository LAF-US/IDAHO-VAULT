.obsidian/plugins/*/main.js
.obsidian/plugins/*/styles.css
.obsidian/plugins/obsidianclaw/
.obsidian/plugins/fit/debug.log
.obsidian/**(2)*.json

!.obsidian/community-plugins.json
!.obsidian/core-plugins.json
!.obsidian/plugins/*/manifest.json
!.obsidian/plugins/roygbiv-day-accent/main.js

# ---------------------------------------------------------------------------
# Editor, OS, and sync noise
# ---------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/mcp.json

.idea/
*.swp
*.swo
*~

.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
._*

# Office temporary lock files, not documents.
~$*.doc
~$*.docx
~$*.xls
~$*.xlsx
~$*.ppt
~$*.pptx

# Obsidian/cloud conflict duplicates and temporary placeholders.
* (Conflicted copy *)*
tempfolder.txt

# ---------------------------------------------------------------------------
# Local intake/runtime holding areas
# ---------------------------------------------------------------------------
tmp-minidata-msg/
tmp-msg-extract/
INBOX/PHONE-LINK/*
DAILYNOTES/

_phone-link-sweep.log
_phone-link-watcher.log
_phone-link-watcher.pid

# Swarm runtime state; durable reports should be promoted to markdown/json
# surfaces intentionally.
!/swarm/logs/*
!!/swarm/logs/*
!/sbp-blackboard.json
.github/swarm/state/archive/

# Explicit local/private holding spaces from the old desktop rule set. These
# are not source-document classes; they are operator-controlled private/runtime
# lanes unless Logan promotes a specific file.
.remember/
_private/
@/
*.vault.json

# ---------------------------------------------------------------------------
# GitHub service surfaces: GitBook and GitGuardian
# ---------------------------------------------------------------------------
# GitBook and GitGuardian are part of the GitHub-side environment. Their
# tracked configuration/documentation surfaces must stay visible to git.
!.gitbook.yaml
!.gitbook/
!.gitbook/**
!.gitguardian/
!.gitguardian/**
!-SUMMARY.md

# Local scanner/build output is churn unless promoted into a durable report.
.gitbook/cache/
.gitbook/tmp/
.gitguardian/cache/
.gitguardian/reports/
ggshield-report.*
gitguardian-report.*

# ---------------------------------------------------------------------------
# rclone/rsync transport surfaces
# ---------------------------------------------------------------------------
# Track durable manifests and vault notes that describe mirrored objects. Do
# not track local transfer credentials, token stores, caches, or partial files.
.rclone-cache/
rclone-cache/
**/.rclone-cache/
**/rclone-cache/

# ---------------------------------------------------------------------------
# NETWEB: Windows reserved device names
# ---------------------------------------------------------------------------
# These names are invalid on Windows regardless of extension. Use the vault
# alias convention instead, e.g. _AUX.md with aliases: [AUX].
[Aa][Uu][Xx]
[Aa][Uu][Xx].*
[Cc][Oo][Nn]
[Cc][Oo][Nn].*
[Nn][Uu][Ll]
[Nn][Uu][Ll].*
[Pp][Rr][Nn]
[Pp][Rr][Nn].*
[Cc][Oo][Mm][0-9]
[Cc][Oo][Mm][0-9].*
[Ll][Pp][Tt][0-9]
[Ll][Pp][Tt][0-9].*

# ---------------------------------------------------------------------------
# Explicit non-rules
# ---------------------------------------------------------------------------
# Do not blanket-ignore media, PDFs, Office files, email files, archives, or
# production source formats here. In this vault those may be source documents.
# Exclude a specific sensitive or draft artifact only by explicit path, a
# separate local exclude rule, or an approved metadata-driven workflow.
